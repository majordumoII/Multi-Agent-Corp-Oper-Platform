# GCP Project
GOOGLE_CLOUD_PROJECT=your-project-id

# Local dev: when true, service-to-service HTTP calls skip OIDC ID-token
# fetch (no metadata server / gcloud ADC required to run everything on
# localhost). Set to false (or unset) on Cloud Run — Cloud Run's runtime
# always supplies ADC, so the OIDC path is taken automatically there.
LOCAL_DEV=true

# --- api_gateway ---
# Base URL of the orchestrator service (Cloud Run URL in production)
ORCHESTRATOR_URL=http://localhost:8081
# Audience for the OIDC ID token minted when calling the orchestrator.
# Defaults to ORCHESTRATOR_URL when unset — override only if the Cloud Run
# service's audience differs from its invocation URL.
ORCHESTRATOR_AUDIENCE=
GATEWAY_PORT=8080
REQUEST_TIMEOUT_SECONDS=60

# --- orchestrator ---
# Base URL of Project 2's Enterprise-RAG-Security-Guardrails /query service
RAG_SERVICE_URL=http://localhost:8000
RAG_SERVICE_AUDIENCE=
ORCHESTRATOR_PORT=8081

# Vertex AI (Gemini) — not yet called in Phase 1's stub Agent A, but
# documented now so Phase 2+ agents don't need a config rewrite.
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-east1
GEMINI_MODEL=gemini-2.0-flash
